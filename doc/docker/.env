# =============================================================================
# Testhub Docker Compose – External Port Configuration
#
# This file is automatically loaded by Docker Compose when running commands
# from the doc/docker/ directory. Override any value to resolve port conflicts
# with other services running on your machine.
#
# Usage:
#   docker compose -f doc/docker/compose-local.yaml --profile full up -d
#
# To override a single port without editing this file:
#   PORT_VSDM_SERVER=19130 docker compose -f doc/docker/compose-local.yaml --profile full up -d
# =============================================================================

